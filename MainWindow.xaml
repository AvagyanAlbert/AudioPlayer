<Window x:Class="AudioPlayer.MainWindow" 
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" 
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" 
        Title="Spotify Player" 
        Height="720" 
        Width="420" 
        WindowStartupLocation="CenterScreen" 
        WindowStyle="None" 
        AllowsTransparency="True" 
        Background="Transparent">
    <Grid>
        <Border CornerRadius="30">
            <Border.Background>
                <RadialGradientBrush>
                    <GradientStop Color="#1DB95420" 
                                  Offset="0"/>
                    <GradientStop Color="#0F0F0F"
                                  Offset="1"/>
                </RadialGradientBrush>
            </Border.Background>
        </Border>
        
        <Grid HorizontalAlignment="Right"
              VerticalAlignment="Top"
              Margin="0,15,15,0" 
              Panel.ZIndex="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="32"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="32"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="32"/>
            </Grid.ColumnDefinitions>
            
            <Button Grid.Column="0" 
                    Content="—" 
                    FontSize="14" 
                    FontWeight="Bold" 
                    Background="#2A2A2A" 
                    Foreground="White" 
                    BorderThickness="0" 
                    Width="32" 
                    Height="32" 
                    Cursor="Hand" 
                    Click="MinimizeButton_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" 
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
            
            <Button Grid.Column="2" 
                    Content="🗖" 
                    FontSize="14" 
                    FontWeight="Bold" 
                    Background="#2A2A2A" 
                    Foreground="White" 
                    BorderThickness="0"
                    Width="32" 
                    Height="32" 
                    Cursor="Hand" 
                    Click="MaximizeButton_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
            
            <Button Grid.Column="4" 
                    Content="✕" 
                    FontSize="12" 
                    FontWeight="Bold" 
                    Background="#FF3B30"
                    Foreground="White"
                    BorderThickness="0" 
                    Width="32" 
                    Height="32" 
                    Cursor="Hand" 
                    Click="CloseButton_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" 
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Grid>
        
        <Border Width="380" 
                Height="680" 
                CornerRadius="28"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Padding="22">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0"
                                     EndPoint="1,1">
                    <GradientStop Color="#FF1A1A1A"
                                  Offset="0"/>
                    <GradientStop Color="#FF101010"
                                  Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Border.Effect>
                <DropShadowEffect BlurRadius="30" 
                                  ShadowDepth="0" 
                                  Opacity="0.4"/>
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="140"/>
                </Grid.RowDefinitions>
                
                <StackPanel Grid.Row="0"
                            VerticalAlignment="Center" 
                            HorizontalAlignment="Center">
                    
                    <Border Width="240" 
                            Height="240" 
                            CornerRadius="22" 
                            Margin="0,0,0,25">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="25" 
                                              ShadowDepth="0"
                                              Color="#1DB954" 
                                              Opacity="0.5"/>
                        </Border.Effect>
                        <Image Source="{Binding CurrentSong.ImagePath}" 
                               Stretch="Fill"/>
                    </Border>
                    
                    <TextBlock Text="{Binding CurrentSong.Title}" 
                               Foreground="White" 
                               FontSize="24" 
                               FontWeight="SemiBold" 
                               HorizontalAlignment="Center"/>
                    
                    <TextBlock Text="{Binding CurrentSong.Artist}" 
                               Foreground="#B8B8B8" 
                               FontSize="14" Margin="0,6,0,0" 
                               HorizontalAlignment="Center"/>
                </StackPanel>
                
                <Border Grid.Row="1" 
                        Background="#1A1A1A" 
                        CornerRadius="20" 
                        Padding="18">
                    <StackPanel>
                        
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding CurrentTime}"
                                       Foreground="#999" 
                                       FontSize="11" 
                                       VerticalAlignment="Center"/>
                            <Slider Grid.Column="1" 
                                    Minimum="0" 
                                    Maximum="100" 
                                    Value="{Binding SongProgress}" 
                                    Height="6" 
                                    Margin="10,0" 
                                    Foreground="#1DB954"/>
                            <TextBlock Grid.Column="2" 
                                       Text="{Binding TotalTime}" 
                                       Foreground="#999" 
                                       FontSize="11" 
                                       VerticalAlignment="Center"/>
                        </Grid>
                        
                        <Grid HorizontalAlignment="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="70"/>
                            </Grid.ColumnDefinitions>
                            
                            <Button Grid.Column="0" 
                                    Command="{Binding PreviousCommand}"
                                    Content="{Binding PreviousButtonText}" 
                                    Foreground="#E5E5E5"
                                    BorderThickness="0" 
                                    Width="56" 
                                    Height="56" 
                                    Margin="5" 
                                    FontSize="18" 
                                    Cursor="Hand">
                                <Button.Background>
                                    <SolidColorBrush Color="#2A2A2A"/>
                                </Button.Background>
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" 
                                                CornerRadius="28">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            
                            <Button Grid.Column="1" 
                                    Command="{Binding PlayPauseCommand}" 
                                    Content="{Binding PlayButtonText}"
                                    Foreground="White" 
                                    BorderThickness="0" 
                                    Width="74" 
                                    Height="74" 
                                    FontSize="22" 
                                    Cursor="Hand">
                                <Button.Background>
                                    <SolidColorBrush Color="#1DB954"/>
                                </Button.Background>
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" 
                                                CornerRadius="37">
                                            <ContentPresenter HorizontalAlignment="Center" 
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                                <Button.Effect>
                                    <DropShadowEffect BlurRadius="20" 
                                                      ShadowDepth="3" 
                                                      Color="#1DB954" 
                                                      Opacity="0.35"/>
                                </Button.Effect>
                            </Button>
                            
                            <Button Grid.Column="2" 
                                    Command="{Binding NextCommand}" 
                                    Content="{Binding NextButtonText}" 
                                    Foreground="#E5E5E5" 
                                    BorderThickness="0" 
                                    Width="56" 
                                    Height="56" 
                                    Margin="5" 
                                    FontSize="18" 
                                    Cursor="Hand">
                                <Button.Background>
                                    <SolidColorBrush Color="#2A2A2A"/>
                                </Button.Background>
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" 
                                                CornerRadius="28">
                                            <ContentPresenter HorizontalAlignment="Center" 
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>